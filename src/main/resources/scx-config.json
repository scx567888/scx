{
  "scx": {
    "port": 8080,
    "allowed-origin": "*",
    "data-source": {
      "url": "jdbc:mysql://127.0.0.1:3306/scx",
      "username": "root",
      "password": "root",
      "parameters": [
        "allowMultiQueries=true",
        "rewriteBatchedStatements=true",
        "createDatabaseIfNotExist=true"
      ]
    },
    "https": {
      "enabled": false,
      "ssl-path": "AppRoot:ssl\\scx_dev.jks",
      "ssl-password": "123456"
    },
    "template": {
      "root": "AppRoot:c"
    },
    "logging": {
      "default": {
        "level": "DEBUG",
        "type": "CONSOLE",
        "stored-directory": "AppRoot:logs",
        "stack-trace": false
      },
      "loggers": [
        {
          "name": "cool.scx.sql.SQLRunner",
          "level": "DEBUG",
          "type": "CONSOLE",
          "stored-directory": "AppRoot:sql-logs",
          "stack-trace": false
        }
      ]
    }
  }
}
